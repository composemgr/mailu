# Mailu Mail Server - Environment Variables
# Copy to app.env and customize

# Timezone
TZ=America/New_York

# Network
IPV4_NETWORK=10.1.1.0/24

# Domain settings
BASE_HOST_NAME=mail.example.com
BASE_DOMAIN_NAME=example.com

# Admin account
APP_ADMIN_USER=admin
APP_ADMIN_PASS=changeme_admin_password

# Application secret key (min 32 chars)
APP_SECRET_KEY=changeme_secret_key_min_32_chars
